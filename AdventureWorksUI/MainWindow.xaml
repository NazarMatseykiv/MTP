<Window x:Class="AdventureWorksUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdventureWorksUI"
        mc:Ignorable="d"
        Title="AdventureWorks Sales Editor"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Loaded="OnWindowLoaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- Верхня панель кнопок -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0,0,0,10">
            <Button Name="backButton"
                Width="90"
                Height="35"
                Margin="0,0,10,0"
                Click="backButton_Click">
                &lt; Back
            </Button>

            <Button Name="nextButton"
                Width="90"
                Height="35"
                Margin="0,0,10,0"
                Click="nextButton_Click">
                Next &gt;
            </Button>

            <Button Name="saveButton"
                Width="130"
                Height="35"
                Click="saveButton_Click">
                Save changes
            </Button>
        </StackPanel>

        <!-- Інформація про поточний запис -->
        <Border Grid.Row="1"
            BorderBrush="Gray"
            BorderThickness="1"
            Padding="10"
            Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="5" FontWeight="Bold" Text="Sales Order ID:"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="5" Text="{Binding SalesOrderId}" IsReadOnly="True"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="5" FontWeight="Bold" Text="Sales Order Number:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding SalesOrderNumber}" IsReadOnly="True"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="5" FontWeight="Bold" Text="Order Date:"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="5" Text="{Binding OrderDate}" IsReadOnly="True"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="5" FontWeight="Bold" Text="Total Due:"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="5" Text="{Binding TotalDue}" IsReadOnly="True"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="5" FontWeight="Bold" Text="Purchase Order Number:"/>
                <TextBox Grid.Row="4" Grid.Column="1" Margin="5" Text="{Binding PurchaseOrderNumber, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="5" FontWeight="Bold" Text="Comment:"/>
                <TextBox Grid.Row="5" Grid.Column="1"
                         Margin="5"
                         Height="70"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <!-- Заголовок блоку деталей -->
        <TextBlock Grid.Row="2"
                   Margin="0,0,0,10"
                   FontSize="16"
                   FontWeight="Bold"
                   Text="Order Details"/>

        <!-- Таблиця деталей -->
        <DataGrid Grid.Row="3"
                  Name="detailsDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0,0,0,0"
                  CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Sales Order Detail ID"
                                    Binding="{Binding SalesOrderDetailId}"
                                    Width="150"/>

                <DataGridTextColumn Header="Product ID"
                                    Binding="{Binding ProductId}"
                                    Width="100"/>

                <DataGridTextColumn Header="Order Qty"
                                    Binding="{Binding OrderQty}"
                                    Width="100"/>

                <DataGridTextColumn Header="Unit Price"
                                    Binding="{Binding UnitPrice}"
                                    Width="120"/>

                <DataGridTextColumn Header="Discount"
                                    Binding="{Binding UnitPriceDiscount}"
                                    Width="120"/>

                <DataGridTextColumn Header="Line Total"
                                    Binding="{Binding LineTotal}"
                                    Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

